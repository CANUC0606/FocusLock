# FocusLock — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores
# NUNCA commite o arquivo .env.local

# Anthropic API (obrigatório para verificação por IA)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (opcional — apenas para sync em Fase 2+)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Configurações do agente (opcional — sobrescreve defaults)
AI_CONFIDENCE_THRESHOLD=60       # Score mínimo para aprovar (0-100)
AI_HISTORY_MAX_ITEMS=50          # Máximo de verificações no contexto
AI_MAX_TOKENS=1000
